---
const links = [['Como funciona','#como-funciona'],['Diagnóstico IA','#demonstracao'],['Infraestrutura','#infraestrutura'],['Oferta','#oferta'],['FAQ','#faq']];
---
<header class="header">
  <a class="brand" href="#top" aria-label="neoflowoff.agency — início">neoflowoff.agency</a>
  <nav aria-label="Navegação principal">{links.map(([label, href]) => <a href={href}>{label}</a>)}</nav>
  <a class="button button-small neo-sdr-link" href="https://chat.neoflowoff.agency">Iniciar diagnóstico <span>↗</span></a>
</header>
<style is:global>
  .brand {
    font: 300 16px/1 Geist, Arial, sans-serif;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
  }
</style>

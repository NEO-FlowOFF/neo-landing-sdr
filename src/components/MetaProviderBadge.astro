---
interface Props {
  variant?: 'light' | 'dark';
  class?: string;
  height?: number;
}
const { class: className = '', height = 40 } = Astro.props;
---

<div class={`meta-provider-badge-wrapper ${className}`} role="status" aria-label="Selo de Autoridade: Meta Tech Provider — Official Partner">
  <img
    src="/assets/badge_meta_tech_provider.png"
    alt="Meta Tech Provider — Official Partner"
    height={height}
    loading="eager"
    decoding="async"
    class="meta-badge-img"
  />
</div>

<style>
  .meta-provider-badge-wrapper {
    display: inline-flex;
    align-items: center;
    user-select: none;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), filter 0.25s ease;
  }

  .meta-provider-badge-wrapper:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 6px 16px rgba(6, 104, 225, 0.25));
  }

  .meta-badge-img {
    height: 40px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 480px) {
    .meta-badge-img {
      height: 34px;
    }
  }
</style>

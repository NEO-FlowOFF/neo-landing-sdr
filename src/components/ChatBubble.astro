---
// src/components/ChatBubble.astro
// Widget bolha flutuante integrado diretamente na Landing Page, rodando via OpenAI na rota /api/chat
import { MessageSquare } from "@lucide/astro";
---

<div id="neo-sdr-widget-container" class="widget-container">
  <!-- Janela do Chat (Drawer flutuante oculta por padrão) -->
  <div id="neo-sdr-drawer" class="chat-drawer" aria-hidden="true">
    <div class="drawer-header">
      <div class="header-status">
        <span class="status-dot"></span>
        <span class="header-title">NEØ:one <small>[agent SDR IA]</small></span>
      </div>
      <div class="header-actions">
        <button id="close-drawer-btn" class="close-btn" aria-label="Fechar chat">×</button>
      </div>
    </div>

    <div id="chat-messages" class="drawer-messages"></div>

    <form id="chat-form" class="drawer-input-bar">
      <input
        type="text"
        id="chat-input"
        placeholder="Digite sua mensagem ou dúvida..."
        autocomplete="off"
        required
      />
      <button type="submit" id="chat-send-btn" class="send-btn" aria-label="Enviar mensagem">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </form>
    <div class="drawer-footer-fallback" style="padding: 6px 14px 10px; text-align: center; font-size: 11px; border-top: 1px solid rgba(255,255,255,.05);">
      <a href="https://wa.me/5562994789032" target="_blank" rel="noopener noreferrer" style="color: #92978f; text-decoration: underline;">Ou falar diretamente pelo WhatsApp ↗</a>
    </div>
  </div>

  <!-- Bolha Flutuante (Botão Acionador) -->
  <button id="neo-sdr-bubble-btn" class="chat-bubble" aria-label="Conversar com Agent SDR">
    <i></i><b><MessageSquare size={28} stroke-width={1.5} /></b>
  </button>
</div>

<script>
  // Controle de estado e requisição no cliente
  const drawer = document.getElementById("neo-sdr-drawer");
  const bubbleBtn = document.getElementById("neo-sdr-bubble-btn");
  const closeBtn = document.getElementById("close-drawer-btn");
  const chatForm = document.getElementById("chat-form") as HTMLFormElement;
  const chatInput = document.getElementById("chat-input") as HTMLInputElement;
  const sendBtn = document.getElementById("chat-send-btn") as HTMLButtonElement;
  const messagesBox = document.getElementById("chat-messages");

  import { initOrGetSession } from "../lib/session-handler";

  let isOpen = false;
  let history: { role: string; content: string }[] = [];
  let hasBootstrapped = false;
  let isSending = false;

  const MAX_HISTORY_LENGTH = 10;

  function pushHistory(item: { role: string; content: string }) {
    history.push(item);
    if (history.length > MAX_HISTORY_LENGTH) {
      history = history.slice(-MAX_HISTORY_LENGTH);
    }
  }

  function setFormDisabled(disabled: boolean) {
    isSending = disabled;
    if (chatInput) chatInput.disabled = disabled;
    if (sendBtn) sendBtn.disabled = disabled;
  }

  async function bootstrapAgentGreeting() {
    if (hasBootstrapped) return;
    hasBootstrapped = true;
    const typingEl = appendTyping();
    const sessionPayload = initOrGetSession();
    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          messages: [{ role: "user", content: "[ABRIU_A_BOLHA_DE_CHAT]" }],
          session: sessionPayload,
        }),
      });
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      if (!res.ok) throw new Error("Status: " + res.status);
      const data = await res.json();
      const reply = data.reply || "Opa! Fique à vontade por aqui. Se travar em algo ou só quiser bater um papo sobre a operação, estou na área.";
      appendMessage("agent", reply);
      pushHistory({ role: "assistant", content: reply });
    } catch (err) {
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      const fallbackMsg = "Opa! Fique à vontade por aqui. Se travar em algo ou só quiser bater um papo sobre a operação, estou na área.";
      appendMessage("agent", fallbackMsg);
      pushHistory({ role: "assistant", content: fallbackMsg });
    }
  }

  function toggleDrawer(open?: boolean) {
    if (!drawer) return;
    isOpen = open !== undefined ? open : !isOpen;
    if (isOpen) {
      drawer.classList.add("open");
      drawer.setAttribute("aria-hidden", "false");
      if (history.length === 0 && !hasBootstrapped) {
        bootstrapAgentGreeting();
      }
      setTimeout(() => chatInput?.focus(), 150);
    } else {
      drawer.classList.remove("open");
      drawer.setAttribute("aria-hidden", "true");
    }
  }

  bubbleBtn?.addEventListener("click", () => toggleDrawer(true));
  closeBtn?.addEventListener("click", () => toggleDrawer(false));

  chatForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!chatInput || isSending) return;
    const userText = chatInput.value.trim();
    if (!userText) return;

    chatInput.value = "";
    appendMessage("user", userText);
    pushHistory({ role: "user", content: userText });

    setFormDisabled(true);
    const typingEl = appendTyping();
    const sessionPayload = initOrGetSession();

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          messages: history,
          session: sessionPayload,
        }),
      });
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      if (!res.ok) throw new Error("Status: " + res.status);
      const data = await res.json();
      const reply = data.reply || "⚠️ Sem conexão. Por favor, tente novamente.";
      appendMessage("agent", reply);
      pushHistory({ role: "assistant", content: reply });
    } catch (err) {
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      const fallbackMsg = "⚠️ Falha na conexão. Verifique sua internet e tente novamente.";
      appendMessage("agent", fallbackMsg);
      pushHistory({ role: "assistant", content: fallbackMsg });
    } finally {
      setFormDisabled(false);
      chatInput?.focus();
    }
  });

  setTimeout(() => {
    if (history.length === 0 && !hasBootstrapped) {
      bootstrapAgentGreeting();
    }
  }, 700);

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function escapeAttribute(s: string) {
    return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function formatMarkdown(text: string) {
    // Purifica caracteres nulos para evitar colisão com placeholders de token
    const sanitizedInput = text.replace(/\u0000/g, '');
    const escaped = escapeHtml(sanitizedInput);
    const lines = escaped.split('\n');
    let inCodeBlock = false;
    const codeLines: string[] = [];
    let listType: 'ul' | 'ol' | null = null;
    let listItems: string[] = [];
    let paraLines: string[] = [];
    let output = '';

    const flushPara = () => {
      if (!paraLines.length) return '';
      const html = `<p>${paraLines.map(l => inlineMarkdown(l)).join(' ')}</p>`;
      paraLines = [];
      return html;
    };

    const inlineMarkdown = (value: string) => {
      const tokens: string[] = [];
      const tokenPrefix = `__NEO_TOKEN_${Math.random().toString(36).substring(2, 8)}_`;
      const preserve = (html: string) => { const index = tokens.push(html) - 1; return `${tokenPrefix}${index}__`; };
      let parsed = value;
      parsed = parsed.replace(/`([^`]+)`/g, (_, codeText) => preserve(`<code>${codeText}</code>`));
      parsed = parsed.replace(/\[([^\]]+)]\(([^)\n]+)\)/g, (_, linkText, url) => {
        const cleanUrl = url.trim().replace(/\s+/g, '%20');
        const safe = /^https?:\/\//i.test(cleanUrl) ? escapeAttribute(cleanUrl) : '#';
        return preserve(`<a href="${safe}" target="_blank" rel="noreferrer noopener">${linkText}</a>`);
      });
      parsed = parsed.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      parsed = parsed.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
      
      const tokenRegex = new RegExp(`${tokenPrefix}(\\d+)__`, 'g');
      parsed = parsed.replace(tokenRegex, (_, index) => tokens[Number(index)] ?? '');
      return parsed;
    };

    const flushList = () => {
      if (!listType) return '';
      const tag = listType === 'ul' ? 'ul' : 'ol';
      const html = `<${tag}>${listItems.map(item => `<li>${inlineMarkdown(item.trim())}</li>`).join('')}</${tag}>`;
      listType = null; listItems = [];
      return html;
    };

    for (const line of lines) {
      if (line.trim().startsWith('```')) {
        if (inCodeBlock) {
          output += `<pre><code>${codeLines.join('\n')}</code></pre>`;
          codeLines.length = 0;
          inCodeBlock = false;
        } else {
          inCodeBlock = true;
        }
        continue;
      }
      if (inCodeBlock) {
        codeLines.push(line);
        continue;
      }
      const headerMatch = line.match(/^\s{0,3}(#{1,6})\s+(.+)$/);
      const blockquoteMatch = line.match(/^\s{0,3}>\s?(.*)$/);
      const unorderedMatch = line.match(/^\s*[-*+]\s+(.+)$/);
      const orderedMatch = line.match(/^\s*(\d+)\.\s+(.+)$/);

      if (headerMatch) { output += flushPara(); output += flushList(); output += `<h${headerMatch[1].length}>${inlineMarkdown(headerMatch[2].trim())}</h${headerMatch[1].length}>`; continue; }
      if (blockquoteMatch) { output += flushPara(); output += flushList(); output += `<blockquote>${inlineMarkdown(blockquoteMatch[1].trim())}</blockquote>`; continue; }
      if (unorderedMatch) { output += flushPara(); if (listType === 'ol') output += flushList(); listType = 'ul'; listItems.push(unorderedMatch[1]); continue; }
      if (orderedMatch) { output += flushPara(); if (listType === 'ul') output += flushList(); listType = 'ol'; listItems.push(orderedMatch[2]); continue; }

      output += flushList();
      if (line.trim() === '') { output += flushPara(); } else { paraLines.push(line); }
    }

    // Flush de blocos de código não finalizados ao fim da mensagem
    if (inCodeBlock && codeLines.length > 0) {
      output += `<pre><code>${codeLines.join('\n')}</code></pre>`;
    }

    output += flushPara();
    output += flushList();
    return output;
  }

  function appendMessage(role: "user" | "agent", text: string) {
    if (!messagesBox) return;
    const item = document.createElement("div");
    item.className = `msg-item ${role}`;
    
    const bubble = document.createElement("div");
    bubble.className = "msg-bubble";
    bubble.innerHTML = formatMarkdown(text);

    item.appendChild(bubble);
    messagesBox.appendChild(item);
    messagesBox.scrollTop = messagesBox.scrollHeight;
  }

  function appendTyping() {
    if (!messagesBox) return null;
    const item = document.createElement("div");
    item.className = "msg-item agent typing";
    item.innerHTML = `
      <div class="msg-bubble">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </div>
    `;
    messagesBox.appendChild(item);
    messagesBox.scrollTop = messagesBox.scrollHeight;
    return item;
  }
</script>

<style is:global>
  .widget-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    font-family: var(--font-body, system-ui, -apple-system, sans-serif);
  }

  /* Bolha Flutuante Acionadora */
  .chat-bubble {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 14px 22px;
    background: rgba(16, 18, 16, 0.65);
    border: 1px solid rgba(237, 255, 0, 0.22);
    border-radius: 100px;
    color: var(--text);
    cursor: pointer;
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.6),
      0 0 20px rgba(237, 255, 0, 0.08);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    backdrop-filter: blur(20px) saturate(140%);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .chat-bubble:hover {
    transform: translateY(-3px) scale(1.02);
    border-color: rgba(237, 255, 0, 0.5);
    box-shadow:
      0 16px 42px rgba(0, 0, 0, 0.8),
      0 0 28px rgba(237, 255, 0, 0.15);
  }

  .chat-bubble i {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--acid);
    box-shadow: 0 0 8px var(--acid);
    animation: pulse 2s infinite;
  }

  .chat-bubble span {
    display: flex;
    flex-direction: column;
    text-align: left;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .chat-bubble span small {
    font-size: 0.72rem;
    color: var(--acid);
    font-weight: 500;
  }

  .chat-bubble b {
    font-size: 1.1rem;
  }

  /* Janela de Chat Flutuante */
  .chat-drawer {
    position: absolute;
    bottom: 74px;
    right: 0;
    width: 380px;
    height: 540px;
    max-height: calc(100vh - 110px);
    background: rgba(16, 18, 16, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.85),
      0 0 40px rgba(0, 0, 0, 0.4);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    backdrop-filter: blur(28px) saturate(160%);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px) scale(0.96);
    transform-origin: bottom right;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .chat-drawer.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* Header */
  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--line);
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--acid);
    box-shadow: 0 0 8px var(--acid);
  }

  .header-title {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .header-title small {
    font-size: 0.68rem;
    color: var(--acid);
    font-family: var(--font-mono, monospace);
    margin-left: 4px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .full-btn {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.2s;
  }

  .full-btn:hover {
    color: var(--acid);
    border-color: var(--acid);
    background: rgba(237, 255, 0, 0.08);
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
    padding: 0 4px;
  }

  .close-btn:hover {
    opacity: 1;
    color: var(--orange);
  }

  /* Área de Mensagens */
  .drawer-messages {
    flex: 1;
    padding: 18px 20px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .drawer-messages::-webkit-scrollbar {
    width: 5px;
  }
  .drawer-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  .drawer-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 10px;
  }

  .msg-item {
    display: flex;
    flex-direction: column;
    max-width: 86%;
  }

  .msg-item.agent {
    align-self: flex-start;
  }

  .msg-item.user {
    align-self: flex-end;
    align-items: flex-end;
  }

  .msg-bubble {
    padding: 12px 16px;
    font-size: 0.9rem;
    line-height: 1.5;
    border-radius: 14px;
    color: var(--text);
  }

  .msg-item.agent .msg-bubble {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top-left-radius: 4px;
  }

  .msg-item.user .msg-bubble {
    background: rgba(237, 255, 0, 0.08);
    border: 1px solid rgba(237, 255, 0, 0.22);
    color: #fff;
    border-top-right-radius: 4px;
  }

  /* Formatação Markdown interna */
  .msg-bubble p {
    margin: 0 0 8px 0;
  }
  .msg-bubble p:last-child {
    margin-bottom: 0;
  }
  .msg-bubble strong {
    font-weight: 700;
    color: inherit;
  }
  .msg-bubble a {
    color: var(--acid);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .msg-bubble a:hover {
    color: var(--orange);
  }
  .msg-bubble ul, .msg-bubble ol {
    margin: 8px 0;
    padding-left: 20px;
  }
  .msg-bubble li {
    margin-bottom: 4px;
  }

  /* Typing Indicator */
  .typing .msg-bubble {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 14px 18px;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--acid);
    border-radius: 50%;
    animation: bounce 1.4s infinite ease-in-out both;
  }
  .dot:nth-child(1) { animation-delay: -0.32s; }
  .dot:nth-child(2) { animation-delay: -0.16s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  /* Input Bar */
  .drawer-input-bar {
    display: flex;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.02);
    border-top: 1px solid var(--line);
  }

  .drawer-input-bar input {
    flex: 1;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 10px 14px;
    color: #fff;
    font-size: 0.88rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .drawer-input-bar input:focus {
    border-color: var(--acid);
    background: rgba(255, 255, 255, 0.07);
  }

  .send-btn {
    background: var(--acid);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    width: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }

  .send-btn:hover:not(:disabled) {
    background: #fff;
    transform: scale(1.05);
  }

  .send-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(0, 255, 102, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(0, 255, 102, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(0, 255, 102, 0); }
  }

  @media (max-width: 480px) {
    .chat-drawer {
      width: calc(100vw - 32px);
      height: 75vh;
      bottom: 74px;
      right: 16px;
    }
  }
</style>

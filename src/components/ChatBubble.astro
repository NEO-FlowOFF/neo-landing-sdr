---
// src/components/ChatBubble.astro
// Widget bolha flutuante integrado diretamente na Landing Page, rodando via OpenAI na rota /api/chat
import { MessageSquare } from "lucide-astro";
---

<div id="neo-sdr-widget-container" class="widget-container">
  <!-- Janela do Chat (Drawer flutuante oculta por padrão) -->
  <div id="neo-sdr-drawer" class="chat-drawer" aria-hidden="true">
    <div class="drawer-header">
      <div class="header-status">
        <span class="status-dot"></span>
        <span class="header-title">NEØ:one <small>[agent SDR IA]</small></span>
      </div>
      <div class="header-actions">
        <button id="close-drawer-btn" class="close-btn" aria-label="Fechar chat">×</button>
      </div>
    </div>

    <div id="chat-messages" class="drawer-messages"></div>

    <form id="chat-form" class="drawer-input-bar">
      <input
        type="text"
        id="chat-input"
        placeholder="Digite sua mensagem ou dúvida..."
        autocomplete="off"
        required
      />
      <button type="submit" class="send-btn" aria-label="Enviar mensagem">
        <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </form>
    <div class="drawer-footer-fallback" style="padding: 6px 14px 10px; text-align: center; font-size: 11px; border-top: 1px solid rgba(255,255,255,.05);">
      <a href="https://wa.me/556262994789032?text=Ol%C3%A1%21+Gostaria+de+avaliar+minha+opera%C3%A7%C3%A3o+com+a+neoflowoff.agency" target="_blank" rel="noopener noreferrer" style="color: #92978f; text-decoration: underline;">Ou falar diretamente pelo WhatsApp ↗</a>
    </div>
  </div>

  <!-- Bolha Flutuante (Botão Acionador) -->
  <button id="neo-sdr-bubble-btn" class="chat-bubble" aria-label="Conversar com Agent SDR">
    <i></i><b><MessageSquare size={28} stroke-width={1.5} /></b>
  </button>
</div>

<script>
  // Controle de estado e requisição no cliente
  const drawer = document.getElementById("neo-sdr-drawer");
  const bubbleBtn = document.getElementById("neo-sdr-bubble-btn");
  const closeBtn = document.getElementById("close-drawer-btn");
  const chatForm = document.getElementById("chat-form") as HTMLFormElement;
  const chatInput = document.getElementById("chat-input") as HTMLInputElement;
  const messagesBox = document.getElementById("chat-messages");

  import { initOrGetSession } from "@/lib/session-handler";

  let isOpen = false;
  let history: { role: string; content: string }[] = [];
  let hasBootstrapped = false;

  async function bootstrapAgentGreeting() {
    if (hasBootstrapped) return;
    hasBootstrapped = true;
    const typingEl = appendTyping();
    const sessionPayload = initOrGetSession();
    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          messages: [{ role: "user", content: "[INICIAR_DIAGNOSTICO]" }],
          session: sessionPayload,
        }),
      });
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      if (!res.ok) throw new Error("Status: " + res.status);
      const data = await res.json();
      const reply = data.reply || "Para avaliarmos sua estrutura comercial: onde está o maior gargalo na sua recepção de leads hoje — tempo de resposta, qualificação ou integração com o CRM?";
      appendMessage("agent", reply);
      history.push({ role: "assistant", content: reply });
    } catch (err) {
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      const fallbackMsg = "Para avaliarmos sua estrutura comercial: onde está o maior gargalo na sua recepção de leads hoje — tempo de resposta, qualificação ou integração com o CRM?";
      appendMessage("agent", fallbackMsg);
      history.push({ role: "assistant", content: fallbackMsg });
    }
  }

  function toggleDrawer(open?: boolean) {
    if (!drawer) return;
    isOpen = open !== undefined ? open : !isOpen;
    if (isOpen) {
      drawer.classList.add("open");
      drawer.setAttribute("aria-hidden", "false");
      if (history.length === 0 && !hasBootstrapped) {
        bootstrapAgentGreeting();
      }
      setTimeout(() => chatInput?.focus(), 150);
    } else {
      drawer.classList.remove("open");
      drawer.setAttribute("aria-hidden", "true");
    }
  }

  bubbleBtn?.addEventListener("click", () => toggleDrawer(true));
  closeBtn?.addEventListener("click", () => toggleDrawer(false));

  chatForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!chatInput) return;
    const userText = chatInput.value.trim();
    if (!userText) return;

    chatInput.value = "";
    appendMessage("user", userText);
    history.push({ role: "user", content: userText });

    const typingEl = appendTyping();
    const sessionPayload = initOrGetSession();
    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          messages: history,
          session: sessionPayload,
        }),
      });
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      if (!res.ok) throw new Error("Status: " + res.status);
      const data = await res.json();
      const reply = data.reply || "Desculpe, tive um breve desvio de rota na conexão com o orquestrador. Pode repetir sua mensagem?";
      appendMessage("agent", reply);
      history.push({ role: "assistant", content: reply });
    } catch (err) {
      if (typingEl && typingEl.parentNode) {
        typingEl.parentNode.removeChild(typingEl);
      }
      const fallbackMsg = "Ocorreu um desvio momentâneo na conexão com nosso nó de borda. Por favor, tente enviar novamente.";
      appendMessage("agent", fallbackMsg);
      history.push({ role: "assistant", content: fallbackMsg });
    }
  });

  setTimeout(() => {
    if (history.length === 0 && !hasBootstrapped) {
      bootstrapAgentGreeting();
    }
  }, 700);

  function appendMessage(role: "user" | "agent", text: string) {
    if (!messagesBox) return;
    const item = document.createElement("div");
    item.className = `msg-item ${role}`;
    
    const label = document.createElement("span");
    label.className = "msg-label";
    label.textContent = role === "user" ? "VISITANTE" : "NEØ:one";

    const bubble = document.createElement("div");
    bubble.className = "msg-bubble";
    bubble.innerHTML = text.replace(/\n/g, "<br/>");

    item.appendChild(label);
    item.appendChild(bubble);
    messagesBox.appendChild(item);
    messagesBox.scrollTop = messagesBox.scrollHeight;
  }

  function appendTyping() {
    if (!messagesBox) return null;
    const item = document.createElement("div");
    item.className = "msg-item agent typing";
    item.innerHTML = `
      <span class="msg-label">NEØ:one</span>
      <div class="msg-bubble">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </div>
    `;
    messagesBox.appendChild(item);
    messagesBox.scrollTop = messagesBox.scrollHeight;
    return item;
  }
</script>

<style>
  .widget-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    font-family: var(--font-body, system-ui, -apple-system, sans-serif);
  }

  /* Bolha Flutuante Acionadora */
  .chat-bubble {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 14px 22px;
    background: rgba(16, 18, 16, 0.65);
    border: 1px solid rgba(237, 255, 0, 0.22);
    border-radius: 100px;
    color: var(--text);
    cursor: pointer;
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.6),
      0 0 20px rgba(237, 255, 0, 0.08);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    backdrop-filter: blur(20px) saturate(140%);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .chat-bubble:hover {
    transform: translateY(-3px) scale(1.02);
    border-color: rgba(237, 255, 0, 0.5);
    box-shadow:
      0 16px 42px rgba(0, 0, 0, 0.8),
      0 0 28px rgba(237, 255, 0, 0.15);
  }

  .chat-bubble i {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--acid);
    box-shadow: 0 0 8px var(--acid);
    animation: pulse 2s infinite;
  }

  .chat-bubble span {
    display: flex;
    flex-direction: column;
    text-align: left;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .chat-bubble span small {
    font-size: 0.72rem;
    color: var(--acid);
    font-weight: 500;
  }

  .chat-bubble b {
    font-size: 1.1rem;
  }

  /* Janela de Chat Flutuante */
  .chat-drawer {
    position: absolute;
    bottom: 74px;
    right: 0;
    width: 380px;
    height: 540px;
    max-height: calc(100vh - 110px);
    background: rgba(16, 18, 16, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.85),
      0 0 40px rgba(0, 0, 0, 0.4);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    backdrop-filter: blur(28px) saturate(160%);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px) scale(0.96);
    transform-origin: bottom right;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .chat-drawer.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* Header */
  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--line);
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--acid);
    box-shadow: 0 0 8px var(--acid);
  }

  .header-title {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .header-title small {
    font-size: 0.68rem;
    color: var(--acid);
    font-family: var(--font-mono, monospace);
    margin-left: 4px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .full-btn {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.2s;
  }

  .full-btn:hover {
    color: var(--acid);
    border-color: var(--acid);
    background: rgba(237, 255, 0, 0.08);
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
    padding: 0 4px;
  }

  .close-btn:hover {
    opacity: 1;
    color: var(--orange);
  }

  /* Área de Mensagens */
  .drawer-messages {
    flex: 1;
    padding: 18px 20px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .drawer-messages::-webkit-scrollbar {
    width: 5px;
  }
  .drawer-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  .drawer-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 10px;
  }

  .msg-item {
    display: flex;
    flex-direction: column;
    max-width: 86%;
  }

  .msg-item.agent {
    align-self: flex-start;
  }

  .msg-item.user {
    align-self: flex-end;
    align-items: flex-end;
  }

  .msg-label {
    font-size: 0.66rem;
    font-family: var(--font-mono, monospace);
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 4px;
    letter-spacing: 0.04em;
  }

  .msg-item.agent .msg-label {
    color: var(--acid);
  }
  .msg-item.user .msg-label {
    color: var(--orange);
  }

  .msg-bubble {
    padding: 12px 16px;
    font-size: 0.9rem;
    line-height: 1.5;
    border-radius: 14px;
    color: var(--text);
  }

  .msg-item.agent .msg-bubble {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top-left-radius: 4px;
  }

  .msg-item.user .msg-bubble {
    background: rgba(237, 255, 0, 0.08);
    border: 1px solid rgba(237, 255, 0, 0.22);
    color: #fff;
    border-top-right-radius: 4px;
  }

  /* Typing Indicator */
  .typing .msg-bubble {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 14px 18px;
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--acid);
    border-radius: 50%;
    animation: bounce 1.4s infinite ease-in-out both;
  }
  .dot:nth-child(1) { animation-delay: -0.32s; }
  .dot:nth-child(2) { animation-delay: -0.16s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
  }

  /* Input Bar */
  .drawer-input-bar {
    display: flex;
    gap: 10px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.02);
    border-top: 1px solid var(--line);
  }

  .drawer-input-bar input {
    flex: 1;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 10px 14px;
    color: #fff;
    font-size: 0.88rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .drawer-input-bar input:focus {
    border-color: var(--acid);
    background: rgba(255, 255, 255, 0.07);
  }

  .send-btn {
    background: var(--acid);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    width: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
  }

  .send-btn:hover {
    background: #fff;
    transform: scale(1.05);
  }

  @keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(0, 255, 102, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(0, 255, 102, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(0, 255, 102, 0); }
  }

  @media (max-width: 480px) {
    .chat-drawer {
      width: calc(100vw - 32px);
      height: 75vh;
      bottom: 74px;
      right: 16px;
    }
  }
</style>

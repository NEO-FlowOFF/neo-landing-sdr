---
interface Props {
  class?: string;
  variant?: 'horizontal' | 'compact';
}

const { class: className = "", variant = 'horizontal' } = Astro.props;
---
<div class:list={["traction-pipeline-wrapper", `variant-${variant}`, className]} aria-hidden="true">
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    viewBox="0 0 400 40" 
    width="100%" 
    height="40" 
    fill="none" 
    preserveAspectRatio="xMidYMid meet"
    class="traction-pipeline-svg"
  >
    <!-- Linha de fluxo base pontilhada -->
    <line x1="0" y1="20" x2="400" y2="20" stroke="currentColor" stroke-opacity="0.18" stroke-width="1.5" stroke-dasharray="4 4"/>
    
    <!-- Nó de Entrada (Origem de Tráfego / Sinais) -->
    <circle cx="40" cy="20" r="4" fill="var(--bg, #101010)" stroke="currentColor" stroke-opacity="0.45" stroke-width="1.5"/>
    <circle cx="40" cy="20" r="1.5" fill="currentColor" fill-opacity="0.4"/>
    
    <!-- Nó de Processamento SDR (Destaque NEØ:one - Acid Green) -->
    <g class="pipeline-core-node">
      <circle cx="200" cy="20" r="8" fill="var(--bg, #101010)" stroke="var(--acid, #EDFF00)" stroke-width="2"/>
      <circle cx="200" cy="20" r="3" fill="var(--acid, #EDFF00)"/>
    </g>
    
    <!-- Nó de Saída/Conversão (Tração & Meta CAPI - Orange) -->
    <circle cx="360" cy="20" r="4" fill="var(--orange, #FF7A05)"/>
  </svg>
</div>

<style>
  .traction-pipeline-wrapper {
    width: 100%;
    margin: 20px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d8dcd3;
    pointer-events: none;
  }

  .traction-pipeline-svg {
    display: block;
    max-width: 400px;
    width: 100%;
    height: auto;
  }

  .variant-compact {
    margin: 10px 0;
  }
  .variant-compact .traction-pipeline-svg {
    max-width: 280px;
    height: auto;
  }

  .pipeline-core-node {
    transform-origin: 200px 20px;
    transition: transform 0.3s ease;
  }

  .traction-pipeline-wrapper:hover .pipeline-core-node {
    transform: scale(1.15);
    filter: drop-shadow(0 0 8px rgba(237, 255, 0, 0.5));
  }
</style>

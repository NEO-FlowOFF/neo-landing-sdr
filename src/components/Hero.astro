---
const steps = ['Lead chega','Agente atende','Intenção identificada','Contato capturado','Comercial recebe'];
---
<section class="hero section light-section" id="top">
  <div class="hero-copy reveal">
    <div class="eyebrow"><i></i> AGENT SDR IA </div>
    <h1>Um Agent SDR IA<br /><span>conectado à sua</span><br />operação comercial.</h1>
    <p class="lead">Atende, identifica intenção, captura contatos, qualifica oportunidades e encaminha cada conversa ao comercial. Diagnóstico e instalação rápida.</p>
    <p class="support"><strong>Operação SDR IA Plug & Play</strong> por neoflowoff.agency, conectando página, agente, dados, Meta CAPI e handoff humano.</p>
    <div class="actions">
      <a class="button" href="#chat" data-open-chat>Diagnostico <span>↗</span></a>
    </div>
  </div>
  <div class="signal-panel reveal" aria-label="Fluxo resumido da operação">
    <div class="panel-top"><span><i></i> OPERAÇÃO ATIVA</span><span>SDR.01</span></div>
    <div class="signal-core"><div class="pulse"></div><span>NEØ:one</span><small>Agent SDR IA</small></div>
    <ol>{steps.map((step, index) => <li class="step-item" style={`--step: ${index};`}><span>0{index + 1}</span><b>{step}</b><i class="step-check">✓</i></li>)}</ol>
    <div class="panel-bottom">SINAL → CONTEXTO → OPORTUNIDADE</div>
  </div>
</section>
<style>
.hero {
  min-height: 730px;
  display: grid;
  grid-template-columns: 1.15fr .85fr;
  gap: 7vw;
  align-items: center;
  padding-top: 100px;
}
.eyebrow {
  font-size: 11px;
  letter-spacing: .18em;
  font-weight: 600;
  color: var(--muted);
}
.eyebrow i {
  display: inline-block;
  width: 7px;
  height: 7px;
  background: var(--acid);
  border-radius: 50%;
  box-shadow: 0 0 12px var(--acid);
  margin-right: 8px;
}
.hero h1 {
  font-family: Space Grotesk, sans-serif;
  letter-spacing: -.055em;
  line-height: .96;
  margin: 28px 0;
  font-weight: 500;
  font-size: clamp(50px, 5.4vw, 82px);
}
.lead {
  max-width: 690px;
  font-size: 19px;
  color: #d5d9d1;
}
.support {
  font-size: 13px;
  color: var(--muted);
}
.actions {
  display: flex;
  align-items: center;
  gap: 30px;
  margin-top: 36px;
}
.signal-panel {
  background: linear-gradient(135deg, rgba(16,18,16,.72), rgba(8,9,8,.85));
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,.1);
  box-shadow: 0 30px 90px rgba(0,0,0,.9), inset 0 1px 1px rgba(255,255,255,.14);
  padding: 22px;
  position: relative;
  border-radius: 12px;
}
.panel-top, .panel-bottom {
  display: flex;
  justify-content: space-between;
  font-size: 9px;
  letter-spacing: .16em;
  color: #6f766d;
}
.panel-top i {
  display: inline-block;
  width: 6px;
  height: 6px;
  background: var(--acid);
  border-radius: 50%;
  margin-right: 6px;
  box-shadow: 0 0 8px var(--acid);
  animation: pulse-blink 1.5s infinite ease-in-out;
}
@keyframes pulse-blink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.35; transform: scale(0.85); }
}
.signal-core {
  height: 190px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-bottom: 1px solid var(--line);
}
.signal-core span {
  font: 300 30px Geist, sans-serif;
  letter-spacing: -0.03em;
  z-index: 2;
}
.signal-core small {
  color: var(--muted);
  z-index: 2;
}
.pulse {
  position: absolute;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: radial-gradient(circle at 32% 28%, rgba(237, 255, 0, 0.18) 0%, rgba(237, 255, 0, 0.04) 45%, rgba(16, 18, 16, 0.65) 85%);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(237, 255, 0, 0.25);
  box-shadow: 0 0 40px rgba(237, 255, 0, 0.18), inset 0 0 28px rgba(237, 255, 0, 0.15);
  pointer-events: none;
}
.pulse::before, .pulse::after {
  content: "";
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 1px solid transparent;
  pointer-events: none;
}
.pulse::before {
  inset: -7px;
  border-top-color: var(--acid);
  border-right-color: rgba(237, 255, 0, 0.35);
  animation: orbit-spin 12s linear infinite;
}
.pulse::after {
  inset: -14px;
  border: 1px dashed rgba(237, 255, 0, 0.32);
  border-left-color: var(--acid);
  border-bottom-color: rgba(237, 255, 0, 0.55);
  animation: orbit-spin-reverse 16s linear infinite;
}
@keyframes orbit-spin {
  0% { transform: rotate(0deg) scaleX(1); }
  50% { transform: rotate(180deg) scaleX(1.03); }
  100% { transform: rotate(360deg) scaleX(1); }
}
@keyframes orbit-spin-reverse {
  0% { transform: rotate(360deg) scaleY(1); }
  50% { transform: rotate(180deg) scaleY(1.03); }
  100% { transform: rotate(0deg) scaleY(1); }
}
.signal-panel ol {
  list-style: none;
  margin: 0;
  padding: 12px 0;
}
.signal-panel li {
  display: grid;
  grid-template-columns: 40px 1fr 20px;
  padding: 12px 0;
  border-bottom: 1px solid #232620;
  align-items: center;
}
.signal-panel li span {
  color: #62685f;
  font: 10px Space Grotesk;
}
.signal-panel li b {
  font-size: 12px;
}
.signal-panel li i {
  color: var(--acid);
  font-style: normal;
}
.signal-panel li.step-item {
  opacity: 0.28;
  transform: translateX(-6px);
  animation: step-activate 8.5s infinite ease-out;
  animation-delay: calc(var(--step) * 1.5s);
}
.signal-panel li.step-item b {
  transition: color 0.3s ease;
}
.signal-panel li.step-item .step-check {
  opacity: 0;
  transform: scale(0.2) rotate(-25deg);
  animation: step-tick 8.5s infinite cubic-bezier(0.34, 1.56, 0.64, 1);
  animation-delay: calc(var(--step) * 1.5s + 0.45s);
}
@keyframes step-activate {
  0% {
    opacity: 0.28;
    transform: translateX(-6px);
    color: #62685f;
  }
  6%, 84% {
    opacity: 1;
    transform: translateX(0);
    color: var(--text);
  }
  94%, 100% {
    opacity: 0.28;
    transform: translateX(-6px);
    color: #62685f;
  }
}
@keyframes step-tick {
  0% {
    opacity: 0;
    transform: scale(0.2) rotate(-25deg);
    text-shadow: none;
  }
  6%, 84% {
    opacity: 1;
    transform: scale(1.15) rotate(0deg);
    text-shadow: 0 0 12px var(--acid);
  }
  94%, 100% {
    opacity: 0.28;
    transform: scale(0.2) rotate(-25deg);
    text-shadow: none;
  }
}
.panel-bottom {
  padding-top: 14px;
  justify-content: center;
}
.hero.light-section {
  background: rgba(222, 221, 211, 0.94);
  backdrop-filter: blur(28px) saturate(140%);
  -webkit-backdrop-filter: blur(28px) saturate(140%);
  color: #a1a1a1;
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
  overflow: hidden;
}
.hero.light-section h1 {
  color: #000000;
}
.hero.light-section h1 span {
  color: var(--olive);
  font-weight: 650;
}
.hero.light-section .lead {
  color: var(--olive);
}
.hero.light-section .support {
  color: var(--olive);
}
.hero.light-section .signal-panel {
  background: linear-gradient(135deg, rgba(16,18,16,.94), rgba(8,9,8,.98));
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  color: #f0f2ed;
  border: 1px solid rgba(237,255,0,.3);
  border-radius: 16px;
  box-shadow: 0 30px 90px rgba(0,0,0,.8), 0 10px 30px rgba(0,0,0,.4), inset 0 1px 1px rgba(255,255,255,.18);
}
.hero.light-section .signal-panel span, .hero.light-section .signal-panel small, .hero.light-section .signal-panel li b {
  color: #f0f2ed;
}
.hero.light-section .signal-panel .panel-top, .hero.light-section .signal-panel .panel-bottom {
  color: #aeb3ab;
}
.hero.light-section .signal-panel li {
  border-bottom-color: #282b27;
}
@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
    min-height: auto;
    padding-top: 70px;
  }
  .hero.light-section {
    border-bottom-left-radius: 28px;
    border-bottom-right-radius: 28px;
  }
  .hero h1 {
    font-size: 49px;
  }
  .signal-panel {
    margin-top: 25px;
  }
}
@media (max-width: 560px) {
  .hero {
    padding-top: 55px;
  }
  .hero h1 {
    font-size: 43px;
  }
  .lead {
    font-size: 16px;
  }
  .actions {
    align-items: stretch;
    flex-direction: column;
    gap: 8px;
  }
}
</style>

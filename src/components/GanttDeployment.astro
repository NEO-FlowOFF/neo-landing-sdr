---
const phases = [
  {
    number: "01",
    title: "Diagnóstico Operacional & Inteligência",
    subtitle: "Arquiteto neoflowoff.agency + Telemetria NEØ:one",
    description: "Auditoria de gargalos na captação atual, mapeamento de regras de negócio, origens de tráfego e absorção de contexto via conversa preliminar com o agente.",
    deliverables: ["Auditoria de canais e CRM", "Mapeamento de intenção real", "Definição de SLAs e roteamento"],
    owner: "ARQUITETURA & NEØ:ONE",
    ownerType: "hybrid",
    startCol: 1,
    spanCol: 2,
    timeLabel: "Dias 01 - 03"
  },
  {
    number: "02",
    title: "Calibração Cognitiva do Agent SDR IA",
    subtitle: "Engenharia de Agentes & Prompting Operacional",
    description: "Configuração do núcleo cognitivo do NEØ:one com tom de voz exclusivo, regras rígidas de qualificação (POI), tratamento de objeções e ofertas canônicas.",
    deliverables: ["Prompt operacional e guardrails", "Matriz de qualificação (POI)", "Calibração de CTAs e gatilhos"],
    owner: "NEØ:ONE COGNITIVE",
    ownerType: "agent",
    startCol: 2,
    spanCol: 2,
    timeLabel: "Dias 03 - 06"
  },
  {
    number: "03",
    title: "Conexão de Superfícies & Infra de Borda",
    subtitle: "Edge Computing (Cloudflare Pages + Workers)",
    description: "Implementação da vitrine webapp responsiva com o componente interativo (ChatBubble), rotas de borda rápidas (/api/chat) e persistência de dados.",
    deliverables: ["Deploy em borda (Cloudflare)", "Rotas de atendimento serverless", "Persistência D1 / KV de leads"],
    owner: "ENGENHARIA DE INFRA",
    ownerType: "arch",
    startCol: 3,
    spanCol: 2,
    timeLabel: "Dias 06 - 09"
  },
  {
    number: "04",
    title: "Handoff Comercial & Roteamento Duplo",
    subtitle: "Integração de CRM e Notificação em Tempo Real",
    description: "Conexão do fluxo qualificado diretamente ao WhatsApp/CRM da equipe comercial (n8n/webhook), entregando o resumo completo da dor do lead no segundo exato.",
    deliverables: ["Integração de webhooks comerciais", "Protocolo de passagem de bastão", "Disparo imediato para vendedor"],
    owner: "OPERAÇÃO COMERCIAL",
    ownerType: "hybrid",
    startCol: 4,
    spanCol: 2,
    timeLabel: "Dias 09 - 12"
  },
  {
    number: "05",
    title: "Camada de Sinais, Meta CAPI & Go-Live",
    subtitle: "Acompanhamento Concierge & Tração Canônica",
    description: "Disparo server-side de eventos de conversão (Meta CAPI + Pixel) para retroalimentar o algoritmo de tráfego, acompanhado de calibração ao vivo na estreia.",
    deliverables: ["Disparo Server-Side Meta CAPI", "Validação de telemetria de ponta a ponta", "Go-Live com assistência Concierge"],
    owner: "CONCIERGE & TRAÇÃO",
    ownerType: "traction",
    startCol: 5,
    spanCol: 2,
    timeLabel: "Dias 12 - 14"
  }
];

import AgentNodeIcon from '../components/AgentNodeIcon.astro';

const whatsappContactUrl = "https://wa.me/5562994789032";
---

<section class="gantt-section depth-acid-noise">
  <div class="gantt-container">
    <div class="gantt-header">
      <div class="header-top">
        <span class="kicker">ARQUITETURA & CRONOGRAMA DE IMPLANTAÇÃO</span>
        <div class="legend-pills">
          <span class="legend-pill arch"><i class="dot arch-dot"></i> Arquiteto de Sistemas</span>
          <span class="legend-pill agent"><AgentNodeIcon size={16} class="legend-node-icon" /> Agent SDR NEØ:one</span>
          <span class="legend-pill hybrid"><i class="dot hybrid-dot"></i> Operação Conjunta</span>
          <span class="legend-pill traction"><i class="dot traction-dot"></i> Meta CAPI / Tração</span>
        </div>
      </div>
      <h2>Do diagnóstico cognitivo ao <br /><em>sistema operando na sua borda.</em></h2>
      <p class="gantt-subtitle">
        A implantação da <strong>Operação SDR IA Plug & Play</strong> não é um onboarding self-service. É uma condução de engenharia onde o diagnóstico absorvido pelo nosso agente <code>NEØ:one</code> orienta a arquitetura técnica exata construída para a sua empresa.
      </p>
    </div>

    <!-- GANTT BOARD (DESKTOP / TABLET) -->
    <div class="gantt-board">
      <!-- TIME AXIS HEADER -->
      <div class="gantt-timeline-axis">
        <div class="axis-label-col">FASE OPERACIONAL / ENTREGÁVEIS</div>
        <div class="axis-tracks-col">
          <div class="time-marker"><span>DIAS 01 - 03</span><small>Diagnóstico</small></div>
          <div class="time-marker"><span>DIAS 04 - 06</span><small>Calibração</small></div>
          <div class="time-marker"><span>DIAS 07 - 09</span><small>Infra de Borda</small></div>
          <div class="time-marker"><span>DIAS 10 - 12</span><small>Handoff & CRM</small></div>
          <div class="time-marker"><span>DIAS 13 - 14</span><small>Go-Live & CAPI</small></div>
          <div class="time-marker"><span>GO-LIVE 🚀</span><small>Operacional</small></div>
        </div>
      </div>

      <!-- GANTT ROWS -->
      <div class="gantt-rows">
        {phases.map((phase) => (
          <article class="gantt-row">
            <!-- LEFT AREA: INFO & DELIVERABLES -->
            <div class="phase-info-col">
              <div class="phase-number-row">
                <span class="phase-num">{phase.number}</span>
                <span class={`owner-badge ${phase.ownerType}`}>{phase.owner}</span>
              </div>
              <h3 class="phase-title">{phase.title}</h3>
              <span class="phase-subtitle">{phase.subtitle}</span>
              <p class="phase-desc">{phase.description}</p>
              
              <ul class="deliverables-list">
                {phase.deliverables.map((item) => (
                  <li><span class="check-icon">✓</span> {item}</li>
                ))}
              </ul>
            </div>

            <!-- RIGHT AREA: GANTT TRACK & BAR -->
            <div class="phase-track-col">
              <!-- Grid vertical lines -->
              <div class="track-grid-lines">
                <div class="grid-line"></div>
                <div class="grid-line"></div>
                <div class="grid-line"></div>
                <div class="grid-line"></div>
                <div class="grid-line"></div>
                <div class="grid-line"></div>
              </div>

              <!-- Bar wrapper using CSS variables for start/span grid alignment -->
              <div class="bar-positioner" style={`--start: ${phase.startCol}; --span: ${phase.spanCol};`}>
                <div class={`gantt-bar-element ${phase.ownerType}`}>
                  <div class="bar-glow"></div>
                  <div class="bar-content">
                    <span class="bar-label">{phase.timeLabel}</span>
                    <span class="bar-status">▪ ATIVO NA IMPLANTAÇÃO</span>
                  </div>
                  <div class="bar-progress-indicator"></div>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- GANTT FOOTER SUMMARY CARD -->
    <div class="gantt-summary-card">
      <div class="summary-meta">
        <div class="meta-item">
          <span class="meta-label">CICLO CANÔNICO DE IMPLANTAÇÃO</span>
          <strong class="meta-value">14 DIAS CORRIDOS</strong>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">
          <span class="meta-label">MODELO DE EXECUÇÃO</span>
          <strong class="meta-value acid-text">CONCIERGE 100% ASSISTIDO</strong>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">
          <span class="meta-label">INTEGRAÇÃO COGNITIVA</span>
          <strong class="meta-value">NEØ:ONE + ARQUITETO SENIOR</strong>
        </div>
      </div>

      <div class="summary-cta-box">
        <div class="cta-copy">
          <span class="kicker">PRÓXIMO PASSO DE GOVERNANÇA</span>
          <h4>Inicie o diagnóstico da sua operação agora</h4>
        </div>
        <div class="cta-buttons">
          <a class="button neo-sdr-link" href={whatsappContactUrl} target="_blank" rel="noopener noreferrer">
            Avaliar operação com NEØ:one <span>↗</span>
          </a>
          <a class="button-ghost text-link" href={whatsappContactUrl} target="_blank" rel="noopener noreferrer">
            Falar com Arquiteto no WhatsApp <span>↗</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gantt-section {
    padding: 80px 5vw 110px;
    background-color: var(--bg, #000000);
    color: var(--text, #f0f2ed);
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .gantt-container {
    max-width: 1240px;
    margin: 0 auto;
  }

  /* --- Header --- */
  .gantt-header {
    margin-bottom: 50px;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 16px;
  }

  .legend-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .legend-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    border-radius: 100px;
    font: 600 11px/1 "Space Grotesk", sans-serif;
    letter-spacing: 0.04em;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #d8dcd3;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .arch-dot { background: var(--acid, #edff00); box-shadow: 0 0 6px var(--acid, #edff00); }
  .agent-dot { background: var(--orange, #ff7a05); box-shadow: 0 0 6px var(--orange, #ff7a05); }
  .hybrid-dot { background: #ffffff; box-shadow: 0 0 6px #ffffff; }
  .traction-dot { background: #70ff00; box-shadow: 0 0 6px #70ff00; }
  .legend-node-icon { margin-right: -2px; }

  .gantt-header h2 {
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.08;
    margin: 0 0 18px;
    font-weight: 700;
  }

  .gantt-header h2 em {
    font-style: italic;
    color: var(--acid, #edff00);
    font-weight: 400;
  }

  .gantt-subtitle {
    font-size: 16px;
    line-height: 1.65;
    color: #aeb3ab;
    max-width: 820px;
    margin: 0;
  }

  .gantt-subtitle code {
    font-family: "Space Grotesk", monospace;
    background: rgba(237, 255, 0, 0.1);
    color: var(--acid, #edff00);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid rgba(237, 255, 0, 0.25);
  }

  /* --- Gantt Board --- */
  .gantt-board {
    background: rgba(16, 18, 16, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.13);
    backdrop-filter: blur(24px) saturate(140%);
    -webkit-backdrop-filter: blur(24px) saturate(140%);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.65);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 40px;
  }

  .gantt-timeline-axis {
    display: grid;
    grid-template-columns: 38% 62%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(0, 0, 0, 0.75);
  }

  .axis-label-col {
    padding: 16px 24px;
    font: 700 11px/1 "Space Grotesk", sans-serif;
    letter-spacing: 0.1em;
    color: #8c9288;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }

  .axis-tracks-col {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    background: rgba(255, 255, 255, 0.015);
  }

  .time-marker {
    padding: 12px 10px;
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .time-marker:last-child {
    border-right: none;
  }

  .time-marker span {
    display: block;
    font: 700 11px/1 "Space Grotesk", sans-serif;
    letter-spacing: 0.05em;
    color: #f0f2ed;
    margin-bottom: 3px;
  }

  .time-marker small {
    display: block;
    font-size: 10px;
    color: #80867c;
  }

  /* --- Gantt Rows --- */
  .gantt-rows {
    display: flex;
    flex-direction: column;
  }

  .gantt-row {
    display: grid;
    grid-template-columns: 38% 62%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.09);
    transition: background-color 0.3s ease;
  }

  .gantt-row:last-child {
    border-bottom: none;
  }

  .gantt-row:hover {
    background: rgba(255, 255, 255, 0.025);
  }

  /* Left Info Column */
  .phase-info-col {
    padding: 26px 24px;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .phase-number-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .phase-num {
    font: 700 16px/1 "Space Grotesk", sans-serif;
    color: var(--acid, #edff00);
  }

  .owner-badge {
    font: 700 9.5px/1 "Space Grotesk", sans-serif;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
  }
  .owner-badge.arch { background: rgba(237, 255, 0, 0.12); color: var(--acid, #edff00); border: 1px solid rgba(237, 255, 0, 0.35); }
  .owner-badge.agent { background: rgba(255, 122, 5, 0.12); color: var(--orange, #ff7a05); border: 1px solid rgba(255, 122, 5, 0.35); }
  .owner-badge.hybrid { background: rgba(255, 255, 255, 0.08); color: #ffffff; border: 1px solid rgba(255, 255, 255, 0.25); }
  .owner-badge.traction { background: rgba(112, 255, 0, 0.12); color: #70ff00; border: 1px solid rgba(112, 255, 0, 0.35); }

  .phase-title {
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 4px;
    color: #ffffff;
    line-height: 1.3;
  }

  .phase-subtitle {
    font-size: 12px;
    color: var(--orange, #ff7a05);
    margin-bottom: 12px;
    display: block;
    font-weight: 500;
  }

  .phase-desc {
    font-size: 13px;
    color: #a0a69b;
    line-height: 1.55;
    margin: 0 0 14px;
  }

  .deliverables-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 6px;
  }

  .deliverables-list li {
    font-size: 12px;
    color: #cfd4c8;
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.35;
  }

  .check-icon {
    color: var(--acid, #edff00);
    font-weight: 700;
    font-size: 11px;
  }

  /* Right Track Column */
  .phase-track-col {
    position: relative;
    display: flex;
    align-items: center;
    padding: 24px 18px;
  }

  .track-grid-lines {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    pointer-events: none;
  }

  .grid-line {
    border-right: 1px dashed rgba(255, 255, 255, 0.06);
  }
  .grid-line:last-child {
    border-right: none;
  }

  .bar-positioner {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    position: relative;
    z-index: 2;
  }

  .gantt-bar-element {
    grid-column: var(--start) / span var(--span);
    height: 60px;
    border-radius: 8px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 16px;
    overflow: hidden;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s ease;
  }

  .gantt-row:hover .gantt-bar-element {
    transform: scaleY(1.04) translateY(-1px);
  }

  .gantt-bar-element.arch {
    background: linear-gradient(135deg, rgba(237, 255, 0, 0.22) 0%, rgba(237, 255, 0, 0.08) 100%);
    border: 1px solid rgba(237, 255, 0, 0.65);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }
  .gantt-bar-element.arch:hover { box-shadow: 0 12px 32px rgba(237, 255, 0, 0.25); }

  .gantt-bar-element.agent {
    background: linear-gradient(135deg, rgba(255, 122, 5, 0.25) 0%, rgba(255, 122, 5, 0.08) 100%);
    border: 1px solid rgba(255, 122, 5, 0.65);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }
  .gantt-bar-element.agent:hover { box-shadow: 0 12px 32px rgba(255, 122, 5, 0.25); }

  .gantt-bar-element.hybrid {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.16) 0%, rgba(255, 255, 255, 0.04) 100%);
    border: 1px solid rgba(255, 255, 255, 0.45);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }
  .gantt-bar-element.hybrid:hover { box-shadow: 0 12px 32px rgba(255, 255, 255, 0.18); }

  .gantt-bar-element.traction {
    background: linear-gradient(135deg, rgba(112, 255, 0, 0.22) 0%, rgba(112, 255, 0, 0.08) 100%);
    border: 1px solid rgba(112, 255, 0, 0.65);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.2);
  }
  .gantt-bar-element.traction:hover { box-shadow: 0 12px 32px rgba(112, 255, 0, 0.25); }

  .bar-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 100%;
  }
  .arch .bar-glow { background: var(--acid, #edff00); box-shadow: 0 0 12px var(--acid, #edff00); }
  .agent .bar-glow { background: var(--orange, #ff7a05); box-shadow: 0 0 12px var(--orange, #ff7a05); }
  .hybrid .bar-glow { background: #ffffff; box-shadow: 0 0 12px #ffffff; }
  .traction .bar-glow { background: #70ff00; box-shadow: 0 0 12px #70ff00; }

  .bar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .bar-label {
    font: 700 13px/1 "Space Grotesk", sans-serif;
    color: #ffffff;
    letter-spacing: 0.02em;
  }

  .bar-status {
    font: 600 10px/1 "Space Grotesk", sans-serif;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.75);
  }

  .bar-progress-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, rgba(255,255,255,0.4), transparent);
  }

  /* --- Summary Card Footer --- */
  .gantt-summary-card {
    background: rgba(16, 18, 16, 0.85);
    border: 1px solid rgba(237, 255, 0, 0.45);
    border-left: 4px solid var(--acid, #edff00);
    border-radius: 12px;
    padding: 32px 36px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.75), inset 0 1px 1px rgba(255, 255, 255, 0.15);
  }

  .summary-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .meta-label {
    font: 600 10.5px/1 "Space Grotesk", sans-serif;
    letter-spacing: 0.08em;
    color: #8c9288;
  }

  .meta-value {
    font: 700 17px/1 "Space Grotesk", sans-serif;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .acid-text {
    color: var(--acid, #edff00);
  }

  .meta-divider {
    width: 1px;
    height: 36px;
    background: rgba(255, 255, 255, 0.12);
  }

  .summary-cta-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }

  .cta-copy h4 {
    font-size: 22px;
    margin: 4px 0 0;
    font-weight: 700;
    color: #ffffff;
  }

  .cta-buttons {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  /* --- Responsive Styles (Tablet & Mobile) --- */
  @media (max-width: 1024px) {
    .gantt-timeline-axis, .gantt-row {
      grid-template-columns: 45% 55%;
    }
    .summary-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .meta-divider {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .gantt-timeline-axis {
      display: none; /* Hide horizontal grid axis on mobile */
    }

    .gantt-row {
      grid-template-columns: 1fr;
      padding: 20px 18px;
    }

    .phase-info-col {
      padding: 0 0 18px;
      border-right: none;
      border-bottom: 1px dashed rgba(255, 255, 255, 0.12);
    }

    .phase-track-col {
      padding: 18px 0 0;
    }

    .track-grid-lines {
      display: none;
    }

    .bar-positioner {
      display: block;
    }

    .gantt-bar-element {
      height: 52px;
      width: 100%;
    }

    .summary-cta-box {
      flex-direction: column;
      align-items: flex-start;
    }

    .cta-buttons {
      width: 100%;
      flex-direction: column;
    }

    .cta-buttons .button, .cta-buttons .button-ghost {
      width: 100%;
      text-align: center;
      justify-content: center;
    }
  }
</style>

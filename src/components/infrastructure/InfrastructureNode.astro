---
export interface NodeProps {
  id: string;
  x: number;
  y: number;
  label: string;
  sublabel?: string;
  microtext?: string;
  telemetry?: string;
  isCore?: boolean;
  nodeWidth?: number;
  nodeHeight?: number;
}

const { 
  x, 
  y, 
  label, 
  sublabel, 
  microtext, 
  telemetry, 
  isCore = false, 
  nodeWidth: propWidth, 
  nodeHeight: propHeight 
} = Astro.props;

const nodeWidth = propWidth ?? (isCore ? 280 : 230);
const nodeHeight = propHeight ?? (isCore ? 116 : 68);
---
<g class:list={["svg-map-node", { "core-node": isCore }]} transform={`translate(${x - nodeWidth/2}, ${y - nodeHeight/2})`}>
  <foreignObject width={nodeWidth} height={nodeHeight} class="node-foreign-object">
    <div class:list={["node-glass-card", { "core-card": isCore }]}>
      <span class="node-entry-pin status-dot"></span>
      <div class="card-content">
        <div class="label-row">
          <span class:list={["card-label", { "core-label-title": isCore }]} title={label}>{label}</span>
        </div>
        {sublabel && <span class:list={["card-sublabel", { "core-sublabel": isCore }]}>{sublabel}</span>}
        {telemetry && (
          <div class="core-telemetry">
            <span class="telemetry-pulse"></span>
            <span class="telemetry-text">{telemetry}</span>
          </div>
        )}
        {microtext && <span class="card-microtext">{microtext}</span>}
      </div>
    </div>
  </foreignObject>
</g>

---
import InfrastructureNode from './InfrastructureNode.astro';
import type { NodeProps } from './InfrastructureNode.astro';

const VIEWBOX_WIDTH = 2000;
const VIEWBOX_HEIGHT = 1200;

// DESKTOP LAYOUT
const nodesDesktop: NodeProps[] = [
  { id: 'd-neo-one', x: 1000, y: 550, label: 'NEØ:one', isCore: true },
  { id: 'd-agent-sdr', x: 1000, y: 620, label: 'AGENT SDR IA', isCore: true, isBeta: true },
  { id: 'd-orchestration', x: 1000, y: 690, label: 'ORCHESTRATION ACTIVE', isCore: true },
  { id: 'd-origin', x: 300, y: 250, label: 'Página / Origem' },
  { id: 'd-intent', x: 650, y: 250, label: 'Intenção' },
  { id: 'd-capture', x: 1000, y: 250, label: 'Captura e consentimento' },
  { id: 'd-qualification', x: 1350, y: 250, label: 'Qualificação' },
  { id: 'd-memory', x: 1000, y: 950, label: 'Data / Memory' },
  { id: 'd-crm', x: 1700, y: 550, label: 'CRM / Pipeline' },
  { id: 'd-handoff', x: 1700, y: 650, label: 'Handoff humano' },
  { id: 'd-conversion', x: 1700, y: 750, label: 'Conversão / Meta CAPI' },
];

const pathsDesktop = [
  { d: 'M 380 250 H 640' }, // origin -> intent
  { d: 'M 730 250 H 990' }, // intent -> capture
  { d: 'M 1000 290 V 540' }, // capture -> neo-one
  { d: 'M 1000 590 V 610' }, // neo-one -> agent-sdr
  { d: 'M 1000 660 V 680' }, // agent-sdr -> orchestration
  { d: 'M 1080 550 C 1200 550, 1350 400, 1350 290' }, // neo-one -> qualification
  { d: 'M 1000 730 V 940' }, // orchestration -> memory
  { d: 'M 1080 950 C 1250 950, 1250 700, 1080 640' }, // memory -> agent-sdr (feedback)
  { d: 'M 1430 250 C 1550 250, 1650 450, 1690 550' }, // qualification -> crm
  { d: 'M 1700 630 V 590' }, // handoff -> crm
  { d: 'M 1700 730 V 590' }, // conversion -> crm
];

// MOBILE LAYOUT (Vertical)
const nodesMobile: NodeProps[] = [
  { id: 'm-origin', x: 1000, y: 150, label: 'Página / Origem' },
  { id: 'm-intent', x: 1000, y: 250, label: 'Intenção' },
  { id: 'm-capture', x: 1000, y: 350, label: 'Captura e consentimento' },
  { id: 'm-neo-one', x: 1000, y: 500, label: 'NEØ:one', isCore: true },
  { id: 'm-agent-sdr', x: 1000, y: 570, label: 'AGENT SDR IA', isCore: true, isBeta: true },
  { id: 'm-orchestration', x: 1000, y: 640, label: 'ORCHESTRATION ACTIVE', isCore: true },
  { id: 'm-qualification', x: 1000, y: 790, label: 'Qualificação' },
  { id: 'm-memory', x: 1000, y: 890, label: 'Data / Memory' },
  { id: 'm-crm', x: 1000, y: 1040, label: 'CRM / Pipeline' },
  { id: 'm-handoff', x: 1000, y: 1140, label: 'Handoff humano' },
  { id: 'm-conversion', x: 1000, y: 1240, label: 'Conversão / Meta CAPI' },
];

const pathsMobile = [
  { d: 'M 1000 190 V 240' }, // origin -> intent
  { d: 'M 1000 290 V 340' }, // intent -> capture
  { d: 'M 1000 390 V 490' }, // capture -> neo-one
  { d: 'M 1000 540 V 560' }, // neo-one -> agent-sdr
  { d: 'M 1000 610 V 630' }, // agent-sdr -> orchestration
  { d: 'M 1000 680 V 780' }, // orchestration -> qualification
  { d: 'M 1000 830 V 880' }, // qualification -> memory
  { d: 'M 1080 890 C 1250 890, 1250 650, 1080 590' }, // memory -> agent-sdr (feedback)
  { d: 'M 1000 930 V 1030' }, // memory -> crm
  { d: 'M 1000 1080 V 1130' }, // crm -> handoff
  { d: 'M 1000 1180 V 1230' }, // handoff -> conversion
];
---

<style is:global>
  @import './infrastructure-map.css';
</style>

<div id="infra-map-wrapper" class="infra-map-container">
  <svg 
    id="infra-map-svg"
    class="infra-map-svg"
    viewBox=`0 0 ${VIEWBOX_WIDTH} ${VIEWBOX_HEIGHT}`
    preserveAspectRatio="xMidYMid meet"
  >
    <defs>
      <pattern id="grid-pattern" width="100" height="100" patternUnits="userSpaceOnUse">
        <path d="M 100 0 L 0 0 0 100" fill="none" stroke="var(--color-grid)" stroke-width="1"/>
      </pattern>
      <marker id="arrowhead" markerWidth="5" markerHeight="3.5" refX="5" refY="1.75" orient="auto">
        <polygon points="0 0, 5 1.75, 0 3.5" class="arrowhead-polygon" />
      </marker>
      <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3.5" result="coloredBlur"/>
        <feMerge>
          <feMergeNode in="coloredBlur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>

    <rect width="100%" height="100%" fill="url(#grid-pattern)" />

    <!-- Desktop Layout -->
    <g class="desktop-layout">
      <g class="connections-group">
        {pathsDesktop.map((path, index) => (
          <path class="connection-path" d={path.d} style={`--animation-delay: ${index * 0.5}s`} />
        ))}
      </g>
      <g class="nodes-group">
        {nodesDesktop.map(node => <InfrastructureNode {...node} />)}
      </g>
      <g class="core-cluster-boundary">
        <rect x="920" y="520" width="160" height="210" rx="15" />
      </g>
    </g>

    <!-- Mobile Layout -->
    <g class="mobile-layout">
       <g class="connections-group">
        {pathsMobile.map((path, index) => (
          <path class="connection-path" d={path.d} style={`--animation-delay: ${index * 0.3}s`} />
        ))}
      </g>
      <g class="nodes-group">
        {nodesMobile.map(node => <InfrastructureNode {...node} />)}
      </g>
      <g class="core-cluster-boundary">
        <rect x="920" y="470" width="160" height="210" rx="15" />
      </g>
    </g>
  </svg>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        } else {
          entry.target.classList.remove('is-visible');
        }
      });
    }, observerOptions);

    const target = document.getElementById('infra-map-wrapper');
    if (target) {
      observer.observe(target);
    }
  });
</script>

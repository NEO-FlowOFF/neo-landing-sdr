import InfrastructureMap from '@/components/infrastructure/InfrastructureMap.astro';
import Layout from '../layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import OperationFlow from '@/components/OperationFlow.astro';
import LiveDemo from '@/components/LiveDemo.astro';
import FAQ from '@/components/FAQ.astro';
import ChatBubble from '@/components/ChatBubble.astro';
const chat = 'https://chat.neoflowoff.agency';
const benefits = [['Menos oportunidades perdidas','Leads são atendidos antes que o interesse desapareça.'],['Mais contexto para o comercial','A equipe recebe nome, contato, origem, necessidade e histórico da conversa.'],['Dados conectados à aquisição','Origem, eventos e conversões continuam sendo registrados.']];
const infra = ['Página','Agent SDR IA','Captura','Dados','CRM','Handoff humano','Meta CAPI'];
const offer = ['Diagnóstico inicial da jornada','Configuração do Agent SDR IA','Adaptação de linguagem e oferta','Página ou superfície de atendimento','Captura e persistência de leads','Identificação de origem','Integração de handoff','Pixel e Meta CAPI','Acompanhamento inicial'];
---
<Layout title="Agent SDR IA · Operação Plug & Play | neoflowoff.agency" description="Agent SDR IA, página, captura de leads, qualificação, handoff humano e Meta CAPI conectados na Operação SDR IA Plug & Play implantada pela neoflowoff.agency.">
  <div class="page-shell"><Header /><main><Hero />
    <section class="section problem depth-acid-noise"><span class="kicker">01 / O PROBLEMA REAL</span><div class="problem-grid"><h2>O lead chegou.<br /><em>A operação é que não estava pronta para recebê-lo.</em></h2><div class="scene reveal"><p>A campanha gera uma mensagem.<br />A pessoa pergunta preço.<br />Alguém demora para responder.</p><p>Quando o comercial assume, já não sabe de onde ela veio, qual anúncio iniciou a conversa ou o que ela realmente queria.</p><strong>O problema não é apenas gerar leads. É conseguir agir enquanto ainda existe intenção.</strong></div></div></section>
    <OperationFlow />
    <section class="section benefits light-section"><div class="section-head"><span class="kicker">03 / IMPACTO</span><h2>O comercial deixa de<br /><em>começar do zero.</em></h2></div><div class="benefit-grid">{benefits.map(([title,copy],i)=><article class="reveal"><span>0{i+1}</span><h3>{title}</h3><p>{copy}</p></article>)}</div></section>
    <LiveDemo />
    {/* <InfrastructureMap /> */}
    <section class="section offer" id="oferta"><div class="offer-copy"><span class="kicker">06 / A OFERTA</span><h2>Operação SDR IA<br /><em>Plug & Play.</em></h2>
      <p>Implantamos uma operação preparada para receber, qualificar e encaminhar oportunidades dentro do fluxo comercial da empresa.</p><div class="concierge">CONCIERGE <span>Configuração conduzida diretamente pela neoflowoff.agency, sem painéis complexos ou onboarding self-service.</span></div><div class="first-deployment-box" style="margin: 24px 0; padding: 22px; background: rgba(16,18,16,.85); border: 1px solid rgba(237,255,0,.3); border-left: 3px solid var(--acid);"><h3 style="margin: 0 0 12px; font: 600 16px Space Grotesk; color: var(--acid);">Primeira implantação</h3><ul style="list-style: none; padding: 0; margin: 0 0 16px; font-size: 13px; color: #cdd2c8; line-height: 1.8;"><li>• diagnóstico da operação atual</li><li>• configuração do agente</li><li>• adaptação da oferta</li><li>• captura e handoff</li><li>• integração inicial de eventos</li><li>• acompanhamento concierge</li></ul><strong style="display: block; font-size: 13px; color: #fff; border-top: 1px solid #232620; padding-top: 12px;">Próximo passo: <span style="color: var(--acid); font-weight: 500;">diagnóstico comercial com a neoflowoff.agency</span></strong></div><div style="display: flex; flex-wrap: wrap; gap: 15px; align-items: center;"><a class="button neo-sdr-link" href={chat}>Avaliar minha operação <span>↗</span></a><a class="text-link" href="https://wa.me/556262994789032?text=Ol%C3%A1%21+Gostaria+de+avaliar+minha+opera%C3%A7%C3%A3o+com+a+neoflowoff.agency" target="_blank" rel="noopener noreferrer">Ou falar pelo WhatsApp <span>↗</span></a></div></div><ul>{offer.map((item,i)=><li class="reveal"><span>0{i+1}</span>{item}<i>✓</i></li>)}</ul></section>
    <section class="section proof"><span class="kicker">07 / PROVA OPERACIONAL</span><div class="proof-grid"><h2>O atendimento na página não é apenas conceito.<br /><em>É a própria arquitetura em ação.</em></h2><div><p>O mesmo sistema utilizado para receber esta conversa faz parte da infraestrutura aplicada pela neoflowoff.agency em páginas, agentes, dados e fluxos comerciais. Status atual da arquitetura:</p><div class="proof-tags">{['Landing: operacional','Agente: operacional','Captura: a validar','Persistência: a validar','Handoff: a validar','Meta CAPI: a validar'].map(x=><span>{x}</span>)}</div></div></div></section>
    <FAQ />
    <section class="section final-cta"><div class="final-signal"><i></i><span>OPERAÇÃO PRONTA PARA RECEBER SINAL</span></div><h2>Se o lead chegou, ele já custou<br /><em>atenção, tempo ou dinheiro.</em></h2><p>Agora precisamos garantir que a operação faça alguma coisa com ele.</p><div style="display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; margin-top: 25px;"><a class="button neo-sdr-link" href={chat}>Iniciar diagnóstico <span>↗</span></a><a class="button button-small" style="background: transparent; border: 1px solid var(--acid); color: var(--text);" href="https://wa.me/556262994789032?text=Ol%C3%A1%21+Gostaria+de+avaliar+minha+opera%C3%A7%C3%A3o+com+a+neoflowoff.agency" target="_blank" rel="noopener noreferrer">Falar pelo WhatsApp <span>↗</span></a></div><small>Converse com o NEØ:one e mostre como os leads chegam hoje na sua empresa.</small></section>
  </main><footer><a class="brand" href="#top">NEØ<span>FLOWOFF</span><small>.agency</small></a><p>Agentes de IA, páginas, CRM e fluxos comerciais para empresas.<br />Marketing com infraestrutura.</p><div><a href="https://www.instagram.com/neoflw.agency" target="_blank" rel="noopener noreferrer">Instagram</a><a href="https://linkedin.com/company/neoflw-agency" target="_blank" rel="noopener noreferrer">LinkedIn</a><a href="https://wa.me/556262994789032?text=Ol%C3%A1%21+Gostaria+de+avaliar+minha+opera%C3%A7%C3%A3o+com+a+neoflowoff.agency" target="_blank" rel="noopener noreferrer">Falar pelo WhatsApp</a><a href={chat} class="neo-sdr-link">Conversar com o NEØ:one</a><a href="/privacidade">Política de Privacidade</a><a href="/termos">Termos de Uso</a><a href="/tratamento-dados">Tratamento de Dados</a></div><small>© {new Date().getFullYear()} neoflowoff.agency</small></footer></div>
  <ChatBubble />
  <script>
    import { setupClientSideSessionTracking } from '@/lib/session-handler';
    setupClientSideSessionTracking();
    const observer = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible') }), { threshold: .12 });
    document.querySelectorAll('.reveal').forEach(e => observer.observe(e));
  </script>
</Layout>
<style is:global>
:root {
  --acid: #EDFF00;
  --orange: #FF7A05;
  --bg: #000000;
  --panel-light: #DEDDD3;
  --olive: #1B1E00;
  --panel: #101210;
  --line: #282b27;
  --text: #f0f2ed;
  --muted: #92978f;
}
* {
  box-sizing: border-box;
}
html {
  scroll-behavior: smooth;
}
body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: Geist, Arial, sans-serif;
  line-height: 1.5;
}
body:before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background-image: linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: linear-gradient(to bottom, black, transparent 70%);
}
a {
  color: inherit;
  text-decoration: none;
}
.page-shell {
  max-width: 1440px;
  margin: auto;
  border-left: 1px solid #171917;
  border-right: 1px solid #171917;
}
.header {
  height: 78px;
  display: flex;
  align-items: center;
  padding: 0 5vw;
  border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  position: sticky;
  top: 0;
  background: rgba(16, 18, 22, 0.68);
  backdrop-filter: blur(28px) saturate(180%);
  -webkit-backdrop-filter: blur(28px) saturate(180%);
  z-index: 20;
  box-shadow: 0 10px 18px -2px rgba(0, 0, 0, 0.82), 0 3px 6px -1px rgba(0, 0, 0, 0.65), inset 0 1px 1px rgba(255, 255, 255, 0.2);
  border-bottom-left-radius: 20px;
  border-bottom-right-radius: 20px;
}
.brand {
  font: 600 18px/1 Space Grotesk;
  letter-spacing: -.8px;
}
.brand span {
  color: var(--acid);
}
.brand small {
  font: 400 11px Geist;
  color: var(--muted);
  margin-left: 3px;
}
.header nav {
  display: flex;
  gap: 30px;
  margin: auto;
  font-size: 13px;
  color: #aeb3ab;
}
.header nav a:hover {
  color: var(--acid);
}
.button {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  gap: 30px;
  min-height: 54px;
  padding: 0 22px;
  background: var(--acid);
  color: #000000;
  font-weight: 650;
  font-size: 14px;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  transition: .2s;
}
.button:hover {
  filter: brightness(1.12);
  transform: translateY(-2px);
}
.button-small {
  min-height: 40px;
  padding: 0 16px;
  gap: 18px;
  font-size: 12px;
}
.section {
  padding: 120px 7vw;
  position: relative;
}
.hero {
  min-height: 730px;
  display: grid;
  grid-template-columns: 1.15fr .85fr;
  gap: 7vw;
  align-items: center;
  padding-top: 100px;
}
.eyebrow {
  font-size: 11px;
  letter-spacing: .18em;
  font-weight: 600;
  color: var(--muted);
}
.kicker {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: .15em;
  color: var(--orange);
  text-shadow: 0 0 8px rgba(255, 122, 5, 0.45);
  display: inline-flex;
  align-items: center;
  background: transparent !important;
  padding: 0 !important;
  border: none !important;
  border-radius: 0 !important;
}
.kicker::before {
  content: ">_ ";
  color: inherit !important;
  text-shadow: inherit !important;
  margin-right: 6px;
  font-weight: 600;
}
.eyebrow i, .final-signal i, .agent-id i {
  display: inline-block;
  width: 7px;
  height: 7px;
  background: var(--acid);
  border-radius: 50%;
  box-shadow: 0 0 12px var(--acid);
  margin-right: 8px;
}
.hero h1, .section h2 {
  font-family: Space Grotesk, sans-serif;
  letter-spacing: -.055em;
  line-height: .96;
  margin: 28px 0;
  font-weight: 500;
}
.hero h1 {
  font-size: clamp(50px, 5.4vw, 82px);
}
h1 span, h2 em {
  color: var(--acid);
  font-style: normal;
}
.lead {
  max-width: 690px;
  font-size: 19px;
  color: #d5d9d1;
}
.support {
  font-size: 13px;
  color: var(--muted);
}
.actions {
  display: flex;
  align-items: center;
  gap: 30px;
  margin-top: 36px;
}
.text-link {
  font-size: 13px;
  border-bottom: 1px solid #50544e;
  padding: 15px 0;
}
.signal-panel {
  background: linear-gradient(135deg, rgba(16,18,16,.72), rgba(8,9,8,.85));
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,.1);
  box-shadow: 0 30px 90px rgba(0,0,0,.9), inset 0 1px 1px rgba(255,255,255,.14);
  padding: 22px;
  position: relative;
  border-radius: 12px;
}
.panel-top, .panel-bottom {
  display: flex;
  justify-content: space-between;
  font-size: 9px;
  letter-spacing: .16em;
  color: #6f766d;
}
.panel-top i {
  display: inline-block;
  width: 5px;
  height: 5px;
  background: var(--acid);
  border-radius: 50%;
  margin-right: 5px;
}
.signal-core {
  height: 190px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-bottom: 1px solid var(--line);
}
.signal-core span {
  font: 600 28px Space Grotesk;
  z-index: 2;
}
.signal-core small {
  color: var(--muted);
  z-index: 2;
}
.pulse {
  position: absolute;
  width: 120px;
  height: 120px;
  border: 1px solid #667204;
  border-radius: 50%;
  box-shadow: 0 0 50px #EDFF0020, inset 0 0 50px #EDFF0020;
}
.signal-panel ol {
  list-style: none;
  margin: 0;
  padding: 12px 0;
}
.signal-panel li, .offer li {
  display: grid;
  grid-template-columns: 40px 1fr 20px;
  padding: 12px 0;
  border-bottom: 1px solid #232620;
  align-items: center;
}
.signal-panel li span, .offer li span {
  color: #62685f;
  font: 10px Space Grotesk;
}
.signal-panel li b {
  font-size: 12px;
}
.signal-panel li i, .offer li i {
  color: var(--acid);
  font-style: normal;
}
.panel-bottom {
  padding-top: 14px;
  justify-content: center;
}
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 50px;
}
.section h2 {
  font-size: clamp(40px, 4.8vw, 69px);
}
.section-head .kicker {
  padding-top: 15px;
}
.problem-grid, .proof-grid {
  display: grid;
  grid-template-columns: 1.15fr .85fr;
  gap: 8vw;
}
.scene {
  padding-top: 30px;
}
.scene p {
  font-size: 18px;
  color: #b7bcb4;
  margin: 0 0 26px;
}
.scene strong {
  display: block;
  border-left: 2px solid var(--orange);
  padding-left: 20px;
  font-size: 16px;
}
.flow-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 70px;
  border-top: 1px solid var(--line);
  border-left: 1px solid var(--line);
}
.flow-card {
  padding: 28px;
  min-height: 250px;
  border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  background: rgba(11,12,11,.75);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transition: all .3s ease;
}
.flow-card:hover {
  background: rgba(18,20,18,.85);
  border-color: rgba(237,255,0,.35);
  box-shadow: 0 15px 40px rgba(0,0,0,.6), inset 0 1px 1px rgba(255,255,255,.1);
  transform: translateY(-3px);
}
.flow-card > div {
  display: flex;
  justify-content: space-between;
  color: #666b64;
  font-size: 11px;
}
.flow-card > div i {
  width: 7px;
  height: 7px;
  border: 1px solid var(--acid);
  border-radius: 50%;
}
.flow-card h3, .benefit-grid h3 {
  font: 500 26px Space Grotesk;
  margin: 55px 0 14px;
}
.flow-card p, .benefit-grid p, .demo p, .offer p, .proof p {
  color: var(--muted);
}
.benefit-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-top: 70px;
}
.benefit-grid article {
  padding: 30px;
  background: var(--panel);
  border-top: 1px solid #394033;
}
.benefit-grid span {
  color: var(--acid);
  font-size: 10px;
}
.demo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8vw;
  background: radial-gradient(circle at 80% 50%, #EDFF0012, transparent 32%);
}
.demo-action {
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(14,16,14,.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 35px;
  box-shadow: 0 20px 50px rgba(0,0,0,.7), inset 0 1px 1px rgba(255,255,255,.1);
  transition: all .3s ease;
}
.demo-action:hover {
  border-color: rgba(237,255,0,.4);
  box-shadow: 0 25px 60px rgba(0,0,0,.8), 0 0 30px rgba(237,255,0,.08), inset 0 1px 1px rgba(255,255,255,.15);
  transform: translateY(-3px);
}
.agent-id {
  display: flex;
  gap: 18px;
  align-items: center;
  border-bottom: 1px solid var(--line);
  padding-bottom: 25px;
}
.agent-mark {
  width: 64px;
  height: 64px;
  border: 1px solid var(--acid);
  display: grid;
  place-items: center;
  font: 600 17px Space Grotesk;
  color: var(--acid);
}
.agent-id strong {
  display: block;
  font: 600 20px Space Grotesk;
}
.agent-id span {
  display: block;
  color: var(--acid);
  font-size: 9px;
  margin-top: 6px;
}
.demo-action p {
  margin: 30px 0;
}
.button-wide {
  width: 100%;
}
.demo-action > small, .final-cta > small {
  display: block;
  color: #6f756c;
  font-size: 11px;
  margin-top: 15px;
  text-align: center;
}
.infra-line {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin: 70px 0;
  position: relative;
}
.infra-line:before {
  content: "";
  height: 1px;
  background: linear-gradient(90deg, var(--acid), var(--orange));
  position: absolute;
  top: 17px;
  left: 3%;
  right: 3%;
}
.infra-node {
  position: relative;
  text-align: center;
}
.infra-node span {
  margin: auto;
  display: grid;
  place-items: center;
  width: 35px;
  height: 35px;
  background: #0b0d0a;
  border: 1px solid var(--acid);
  border-radius: 50%;
  font-size: 9px;
  color: var(--acid);
  position: relative;
}
.infra-node b {
  display: block;
  margin-top: 15px;
  font-size: 12px;
}
.infra-bottom {
  display: flex;
  justify-content: space-between;
  gap: 10vw;
  border-top: 1px solid var(--line);
  padding-top: 30px;
}
.infra-bottom p {
  max-width: 680px;
  color: var(--muted);
  font-size: 13px;
}
.infra-bottom strong {
  max-width: 350px;
}
.offer {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8vw;
}
.concierge {
  display: flex;
  gap: 20px;
  color: var(--acid);
  font-size: 10px;
  letter-spacing: .1em;
  border: 1px solid rgba(237,255,0,.25);
  background: rgba(27,30,0,.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: inset 0 1px 1px rgba(255,255,255,.1);
  padding: 18px;
  margin: 30px 0;
}
.concierge span {
  color: #a8ada5;
  letter-spacing: 0;
  font-size: 12px;
}
.offer ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.offer li {
  grid-template-columns: 45px 1fr 20px;
  padding: 16px 0;
  font-size: 14px;
}
.proof {
  background: #000000;
}
.proof-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 35px;
}
.proof-tags span {
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.03);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 9px 12px;
  font-size: 11px;
  color: #b3b8b0;
  transition: all .2s ease;
}
.proof-tags span:hover {
  border-color: rgba(237,255,0,.4);
  background: rgba(237,255,0,.06);
  color: #fff;
}
.faq-list {
  margin-top: 60px;
  border-top: 1px solid var(--line);
}
details {
  border-bottom: 1px solid var(--line);
}
summary {
  cursor: pointer;
  list-style: none;
  display: grid;
  grid-template-columns: 60px 1fr 30px;
  padding: 24px 0;
  font: 500 18px Space Grotesk;
}
summary span {
  font: 10px Geist;
  color: #62675f;
  padding-top: 6px;
}
summary i {
  color: var(--acid);
  font-style: normal;
  font-size: 22px;
  transition: .2s;
}
details[open] summary i {
  transform: rotate(45deg);
}
details p {
  margin: 0 60px 25px;
  max-width: 700px;
  color: var(--muted);
}
.final-cta {
  text-align: center;
  padding-top: 140px;
  padding-bottom: 140px;
  background: radial-gradient(circle at 50% 60%, #EDFF0012, transparent 35%);
}
.final-signal {
  color: var(--muted);
  font-size: 9px;
  letter-spacing: .18em;
}
.final-cta p {
  color: var(--muted);
  font-size: 17px;
}
.final-cta .button {
  margin-top: 25px;
}
footer {
  padding: 60px 7vw;
  display: grid;
  grid-template-columns: 1fr 2fr 2fr auto;
  gap: 35px;
  align-items: start;
}
footer p {
  font-size: 12px;
  color: var(--muted);
  margin: 0;
}
footer > div {
  display: flex;
  flex-wrap: wrap;
  gap: 18px;
  font-size: 11px;
}
footer > small {
  color: #5d625a;
  font-size: 9px;
}
.chat-bubble {
  position: fixed;
  right: 24px;
  bottom: 24px;
  background: rgba(27,30,0,.75);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(237,255,0,.28);
  padding: 12px 14px;
  display: flex;
  align-items: center;

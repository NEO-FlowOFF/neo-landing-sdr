---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import GanttDeployment from '@/components/GanttDeployment.astro';
import ChatBubble from '@/components/ChatBubble.astro';
import MetaProviderBadge from '@/components/MetaProviderBadge.astro';
import AgentNodeIcon from '@/components/AgentNodeIcon.astro';

const chat = 'https://chat.neoflowoff.agency';
const offer = [
  'Diagnóstico inicial da jornada e regras de negócio',
  'Configuração cognitiva do Agent SDR IA (NEØ:one)',
  'Adaptação de linguagem, tom de voz e oferta canônica',
  'Página ou superfície responsiva de atendimento',
  'Captura e persistência estruturada de leads (POI)',
  'Identificação milimétrica de origem e canais de tráfego',
  'Integração de handoff imediato ao WhatsApp/CRM',
  'Disparo Server-Side (Meta Pixel e Meta CAPI)',
  'Acompanhamento inicial com assistência Concierge'
];
---

<Layout 
  title="A Oferta & Cronograma de Implantação | neoflowoff.agency" 
  description="Conheça a Operação SDR IA Plug & Play implantada pela neoflowoff.agency. Do diagnóstico arquitetural absorvido com o NEØ:one até o go-live do seu fluxo comercial em 14 dias."
>
  <div class="page-shell">
    <Header />
    <main>
      <section class="section offer-header depth-acid-noise">
        <div class="offer-copy">
          <span class="kicker">06 / A OFERTA INSTITUCIONAL</span>
          <h1>Operação SDR IA<br /><em>Plug & Play.</em></h1>
          <p class="lead-text">
            Implantamos uma operação completa e preparada para receber, qualificar e encaminhar oportunidades de forma contínua dentro do fluxo comercial da sua empresa.
          </p>
          <div class="concierge">
            <div class="concierge-tag">
              <AgentNodeIcon size={34} class="concierge-node-icon" />
              <span>CONCIERGE</span>
            </div>
            <p class="concierge-copy">
              Configuração conduzida diretamente pela engenharia da neoflowoff.agency, sem painéis complexos ou onboarding self-service que tomam tempo da sua equipe.
            </p>
          </div>

          <div class="offer-actions">
            <a class="button neo-sdr-link" href={chat}>
              Avaliar minha operação com IA <span>↗</span>
            </a>
            <a class="text-link" href="https://wa.me/556262994789032?text=Ol%C3%A1%21+Gostaria+de+conhecer+a+implanta%C3%A7%C3%A3o+da+Opera%C3%A7%C3%A3o+SDR+IA+Plug+%26+Play" target="_blank" rel="noopener noreferrer">
              Falar com Arquiteto de Sistemas <span>↗</span>
            </a>
          </div>
        </div>

        <div class="offer-checklist">
          <div class="checklist-header">
            <AgentNodeIcon size={24} class="checklist-icon" />
            <span class="kicker">ENTREGÁVEIS DA ARQUITETURA</span>
          </div>
          <ul>
            {offer.map((item, i) => (
              <li class="reveal">
                <span class="num">0{i + 1}</span>
                <span class="item-text">{item}</span>
                <i class="check">✓</i>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- GRÁFICO DE GANTT / CRONOGRAMA DA IMPLANTAÇÃO -->
      <GanttDeployment />
    </main>

    <footer>
      <div class="footer-brand">
        <a class="brand" href="/" aria-label="neoflowoff.agency — início">neoflowoff.agency</a>
        <MetaProviderBadge variant="dark" />
      </div>
      <p>Agentes de IA, páginas, CRM e fluxos comerciais para empresas.<br />Marketing com infraestrutura.</p>
      <div class="footer-links">
        <a href="https://www.instagram.com/neoflw.agency" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://linkedin.com/company/neoflw-agency" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://wa.me/556262994789032?text=Ol%C3%A1%21+Gostaria+de+avaliar+minha+opera%C3%A7%C3%A3o+com+a+neoflowoff.agency" target="_blank" rel="noopener noreferrer">Falar pelo WhatsApp</a>
        <a href={chat} class="neo-sdr-link">Conversar com o NEØ:one</a>
        <a href="/privacidade">Política de Privacidade</a>
        <a href="/termos">Termos de Uso</a>
        <a href="/tratamento-dados">Tratamento de Dados</a>
      </div>
      <small>© {new Date().getFullYear()} neoflowoff.agency</small>
    </footer>
  </div>
  <ChatBubble />
  <script>
    import { setupClientSideSessionTracking } from '@/lib/session-handler';
    setupClientSideSessionTracking();
    const observer = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible') }), { threshold: .12 });
    document.querySelectorAll('.reveal').forEach(e => observer.observe(e));
  </script>
</Layout>

<style>
  .offer-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 7vw;
    padding: 100px 5vw 80px;
    background: var(--bg, #000000);
    color: var(--text, #f0f2ed);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .offer-copy h1 {
    font-size: clamp(38px, 5.5vw, 62px);
    line-height: 1.05;
    margin: 8px 0 24px;
    font-weight: 700;
  }

  .offer-copy h1 em {
    font-style: italic;
    color: var(--acid, #edff00);
    font-weight: 400;
  }

  .lead-text {
    font-size: 17px;
    line-height: 1.65;
    color: #cdd2c8;
    margin: 0 0 28px;
  }

  .concierge {
    display: flex;
    gap: 20px;
    align-items: center;
    border: 1px solid rgba(237, 255, 0, 0.35);
    background: rgba(27, 30, 0, 0.65);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.15), 0 12px 30px rgba(0, 0, 0, 0.45);
    padding: 22px 24px;
    margin: 34px 0;
    border-radius: 12px;
  }

  .concierge-tag {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding-right: 20px;
    border-right: 1px solid rgba(237, 255, 0, 0.25);
    flex-shrink: 0;
  }

  .concierge-tag span {
    font: 700 11px/1 "Space Grotesk", sans-serif;
    letter-spacing: 0.12em;
    color: var(--acid, #edff00);
  }

  .concierge-copy {
    color: #d8dcd3;
    letter-spacing: 0;
    font: 400 13.5px/1.55 var(--font-family-sans, sans-serif);
    margin: 0;
  }

  .offer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: center;
    margin-top: 36px;
  }

  .offer-checklist {
    background: rgba(16, 18, 16, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.13);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-radius: 12px;
    padding: 34px 38px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
  }

  .checklist-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 2px;
  }

  .checklist-header .kicker {
    margin: 0;
  }

  .offer-checklist ul {
    list-style: none;
    padding: 0;
    margin: 20px 0 0;
  }

  .offer-checklist li {
    display: grid;
    grid-template-columns: 42px 1fr 24px;
    align-items: center;
    padding: 16px 0;
    font-size: 14.5px;
    color: #e6e9e2;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .offer-checklist li:last-child {
    border-bottom: none;
  }

  .offer-checklist .num {
    font: 700 13px/1 "Space Grotesk", monospace;
    color: var(--orange, #ff7a05);
  }

  .offer-checklist .item-text {
    line-height: 1.4;
  }

  .offer-checklist .check {
    font-style: normal;
    color: var(--acid, #edff00);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .offer-header {
      grid-template-columns: 1fr;
      padding: 60px max(24px, env(safe-area-inset-right)) 60px max(24px, env(safe-area-inset-left));
    }
    .concierge {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
      padding: 18px max(20px, env(safe-area-inset-right)) 18px max(20px, env(safe-area-inset-left));
    }
    .concierge-tag {
      flex-direction: row;
      border-right: none;
      border-bottom: 1px solid rgba(237, 255, 0, 0.25);
      padding-right: 0;
      padding-bottom: 12px;
      width: 100%;
      justify-content: flex-start;
    }
    .offer-checklist {
      padding: 24px max(22px, env(safe-area-inset-right)) 24px max(22px, env(safe-area-inset-left));
    }
  }

  @media (max-width: 560px) {
    .offer-header {
      padding: 45px max(20px, env(safe-area-inset-right)) 45px max(20px, env(safe-area-inset-left));
    }
    .offer-checklist li {
      grid-template-columns: 32px 1fr 20px;
      gap: 8px;
      font-size: 13.5px;
    }
  }
</style>

{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*", "astro.config.*"],
  "exclude": [
    "dist",
    "public",
    "node_modules",
    ".git",
    ".vercel",
    ".netlify",
    "coverage"
  ]
}
